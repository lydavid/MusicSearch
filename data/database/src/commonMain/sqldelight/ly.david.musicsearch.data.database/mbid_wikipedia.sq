CREATE TABLE mbid_wikipedia (
  mbid TEXT NOT NULL,
  language_tag TEXT NOT NULL,
  extract TEXT NOT NULL,
  url TEXT NOT NULL,

  PRIMARY KEY (mbid, language_tag)
);

insert:
INSERT OR IGNORE INTO mbid_wikipedia
VALUES ?;

get:
SELECT
  extract,
  url
FROM mbid_wikipedia
WHERE mbid = :mbid AND language_tag = :languageTag
LIMIT 1;

deleteByIdAndTag:
DELETE FROM mbid_wikipedia
WHERE mbid = :mbid AND language_tag = :languageTag;
